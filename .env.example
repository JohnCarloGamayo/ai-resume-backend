OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/elephant-alpha
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REQUEST_TIMEOUT_SECONDS=45
OPENROUTER_MAX_RETRIES=3
DAILY_EVALUATION_LIMIT=5
RATE_LIMIT_BYPASS_IPS=127.0.0.1,::1,localhost
# Use * to allow all origins (recommended for quick deployment),
# or provide a comma-separated list of allowed origins.
CORS_ALLOW_ORIGINS=*
